{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "Food Delivery Platform — Request rates, error rates, latency, and order metrics",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Request Rates",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "options": { "legend": { "displayMode": "list" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"user-service\"}[1m]))",
          "legendFormat": "user-service",
          "refId": "A"
        },
        {
          "expr": "sum(rate(http_requests_total{job=\"restaurant-service\"}[1m]))",
          "legendFormat": "restaurant-service",
          "refId": "B"
        },
        {
          "expr": "sum(rate(http_requests_total{job=\"order-service\"}[1m]))",
          "legendFormat": "order-service",
          "refId": "C"
        },
        {
          "expr": "sum(rate(http_requests_total{job=\"delivery-service\"}[1m]))",
          "legendFormat": "delivery-service",
          "refId": "D"
        }
      ],
      "title": "Request Rate per Service (req/s)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "percentunit",
          "max": 1,
          "min": 0
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 2,
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"user-service\",status=~\"5..\"}[1m])) / sum(rate(http_requests_total{job=\"user-service\"}[1m]))",
          "legendFormat": "user-service error rate",
          "refId": "A"
        },
        {
          "expr": "sum(rate(http_requests_total{job=\"restaurant-service\",status=~\"5..\"}[1m])) / sum(rate(http_requests_total{job=\"restaurant-service\"}[1m]))",
          "legendFormat": "restaurant-service error rate",
          "refId": "B"
        },
        {
          "expr": "sum(rate(http_requests_total{job=\"order-service\",status=~\"5..\"}[1m])) / sum(rate(http_requests_total{job=\"order-service\"}[1m]))",
          "legendFormat": "order-service error rate",
          "refId": "C"
        },
        {
          "expr": "sum(rate(http_requests_total{job=\"delivery-service\",status=~\"5..\"}[1m])) / sum(rate(http_requests_total{job=\"delivery-service\"}[1m]))",
          "legendFormat": "delivery-service error rate",
          "refId": "D"
        }
      ],
      "title": "Error Rate per Service (5xx)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 101,
      "title": "Latency",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 3,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"user-service\"}[5m])) by (le))",
          "legendFormat": "user-service p95",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"restaurant-service\"}[5m])) by (le))",
          "legendFormat": "restaurant-service p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"order-service\"}[5m])) by (le))",
          "legendFormat": "order-service p95",
          "refId": "C"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"delivery-service\"}[5m])) by (le))",
          "legendFormat": "delivery-service p95",
          "refId": "D"
        }
      ],
      "title": "P95 Latency per Service",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 4,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(order_processing_seconds_bucket[5m])) by (le))",
          "legendFormat": "order processing p95",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(order_processing_seconds_bucket[5m])) by (le))",
          "legendFormat": "order processing p50",
          "refId": "B"
        }
      ],
      "title": "Order Processing Time (p50 / p95)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 102,
      "title": "Order Metrics",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "green", "mode": "fixed" },
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 19 },
      "id": 5,
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "orders_total{status=\"success\"}",
          "legendFormat": "Successful Orders",
          "refId": "A"
        }
      ],
      "title": "Total Successful Orders",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "red", "mode": "fixed" },
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }] }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 19 },
      "id": 6,
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "failed_orders_total",
          "legendFormat": "Failed Orders",
          "refId": "A"
        }
      ],
      "title": "Total Failed Orders",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "id": 7,
      "targets": [
        {
          "expr": "rate(orders_total{status=\"success\"}[1m])",
          "legendFormat": "successful orders/s",
          "refId": "A"
        },
        {
          "expr": "rate(failed_orders_total[1m])",
          "legendFormat": "failed orders/s",
          "refId": "B"
        }
      ],
      "title": "Order Throughput (per second)",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["food-delivery", "microservices"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Food Delivery Platform",
  "uid": "food-delivery-main",
  "version": 1
}
