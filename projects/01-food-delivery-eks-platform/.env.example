# ============================================================
# FoodRush — Environment Variables Reference
# Copy to .env and fill in values (never commit .env to git)
# ============================================================

# ─── User Service ──────────────────────────────────────────
# SQLite database file path (auto-created on first run)
DATABASE_URL=/data/users.db

# JWT signing secret — change in production to a random 32+ char string
JWT_SECRET_KEY=food-delivery-super-secret-key-2024-change-in-prod

# How long JWT access tokens are valid (minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── Restaurant Service ────────────────────────────────────
# DATABASE_URL=/data/restaurants.db   (same var, different file per service)

# ─── Order Service ─────────────────────────────────────────
# DATABASE_URL=/data/orders.db

# URL of the restaurant service for menu validation
RESTAURANT_SERVICE_URL=http://restaurant-service:8002

# Failure injection mode — set to "true" to make 50% of POST /orders return 500
# Used for observability demos and chaos engineering training
ORDER_SERVICE_FAILURE_MODE=false

# ─── Delivery Service ──────────────────────────────────────
# DATABASE_URL=/data/delivery.db

# ─── Docker Compose (override values) ──────────────────────
# Grafana admin credentials
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=foodrush123
GF_USERS_ALLOW_SIGN_UP=false

# ─── AWS / Terraform (local development) ───────────────────
# AWS credentials (use IAM roles in CI/CD — never hardcode here)
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_DEFAULT_REGION=us-east-1

# Terraform variables
TF_VAR_aws_region=us-east-1
TF_VAR_project_name=food-delivery
TF_VAR_environment=dev
TF_VAR_eks_node_instance_type=t3.small

# ─── GitHub Actions Secrets (set in GitHub repo settings) ──
# AWS_ACCESS_KEY_ID        — from terraform output github_actions_access_key_id
# AWS_SECRET_ACCESS_KEY    — from terraform output github_actions_secret_access_key
# AWS_ACCOUNT_ID           — your 12-digit AWS account ID (for ECR registry URL)
