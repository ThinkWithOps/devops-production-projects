aws_region             = "us-east-1"
project_name           = "food-delivery"
environment            = "dev"
eks_node_instance_type = "t3.small"
eks_node_desired_size  = 2
eks_node_min_size      = 1
eks_node_max_size      = 4

# IAM user/role ARNs that should be able to view Kubernetes resources in the EKS console.
eks_console_admin_principal_arns = []
